#!/dis/sh.dis
# InferNode shell initialization
load std

# Set command search path
path=(/dis .)

# Get username
user="{cat /dev/user}

# Mount namespace generator (creates /n as a synthetic mount point)
mount -ac {mntgen} /n >[2] /dev/null

# Initialize IP networking stack
bind -a '#I' /net >[2] /dev/null

# Start connection server (DNS resolution)
ndb/cs

# Setup home directory and LLM service based on platform
if {~ $emuhost MacOSX Linux}{
	# Start secstore and factotum
	auth/secstored >[2] /dev/null &
	sleep 1
	if {! ftest -f /mnt/factotum/proto}{
		auth/factotum
	}

	# Provision API keys into factotum from host
	factotumkey=`{os sh -c 'k=${ANTHROPIC_API_KEY:-$(plutil -extract EnvironmentVariables.ANTHROPIC_API_KEY raw ~/Library/LaunchAgents/com.nervsystems.llm9p.plist 2>/dev/null)}; if [ -n "$k" ]; then echo "key proto=pass service=anthropic user=apikey !password=$k"; fi'}
	echo $factotumkey > /mnt/factotum/ctl >[2] /dev/null

	# LLM service: read config from /lib/ndb/llm
	llmmode=`{sed -n 's/^mode=//p' /lib/ndb/llm >[2] /dev/null}
	if {~ $llmmode remote} {
		llmdial=`{sed -n 's/^dial=//p' /lib/ndb/llm}
		mount -A $llmdial /n/llm >[2] /dev/null
	}{
		llmsrv >[2] /dev/null &
	}

	# Start speech file server (TTS/STT via /n/speech)
	/dis/veltro/speech9p.dis -e cmd &

	# Mount host filesystem (synchronous)
	trfs '#U*' /n/local >[2] /dev/null
	# Get actual HOME from host
	ghome=/n/local/^`{echo 'echo $HOME' | os sh}
	home=$ghome
}{~ $emuhost Nt}{
	# Windows: start LLM service from lib/veltro/llm.cfg
	if {ftest -f /lib/veltro/llm.cfg} {
		llmbackend=${hd `{sed -n 's/^backend=//p' /lib/veltro/llm.cfg}}
		llmurl=${hd `{sed -n 's/^url=//p' /lib/veltro/llm.cfg}}
		llmmodel=${hd `{sed -n 's/^model=//p' /lib/veltro/llm.cfg}}
		if {~ $llmbackend openai} {
			llmsrv -b openai -u $llmurl -M $llmmodel >[2] /dev/null &
		}{
			llmsrv >[2] /dev/null &
		}
	}{
		llmsrv >[2] /dev/null &
	}

	# Mount host filesystem
	trfs '#U*' /n/local >[2] /dev/null
	home=/usr/^$user
	if {! ftest -d $home} {
		mkdir -p $home
	}
}{
	# Non-desktop platforms (e.g. native Inferno on embedded hardware):
	mount -A 'tcp!llmserver!5640' /n/llm >[2] /dev/null

	home=/usr/^$user
	if {! ftest -d $home} {
		mkdir -p $home
	}
}

# Create tmp directory if needed
if {! ftest -d $home/tmp} {
	mkdir -p $home/tmp
}

# Create /tmp directly (needed on Windows where bind -bc may fail)
mkdir -p /tmp >[2] /dev/null

# Bind home tmp to /tmp so applications can find it
bind -bc $home/tmp /tmp >[2] /dev/null

# Clean up stale temp files from previous sessions
# These accumulate when apps crash (ORCLOSE doesn't trigger on abnormal exit)
# Pattern: /tmp/[A-Z]{pid}.{user}xenith, acme, blks (4-char user prefix)
for f in /tmp/*.????xenith /tmp/*.????acme /tmp/*.????blks {
	rm $f >[2] /dev/null
}

# Change to home directory
cd $home